[sub_resource type="Shader" id="Shader_tower_brick"]
code = "shader_type spatial;
render_mode cull_disabled;

uniform vec4 brick_color : source_color = vec4(0.66, 0.28, 0.18, 1.0);
uniform vec4 mortar_color : source_color = vec4(0.80, 0.77, 0.72, 1.0);
uniform float brick_rows = 120.0;
uniform float brick_columns = 80.0;
uniform float mortar_thickness = 0.08;
uniform float variation_strength = 0.12;

void fragment() {
	vec2 uv = UV;
	float row = floor(uv.y * brick_rows);
	float row_offset = mod(row, 2.0) * 0.5;

	vec2 brick_uv = vec2(fract(uv.x * brick_columns + row_offset), fract(uv.y * brick_rows));

	float x_mask = step(mortar_thickness, brick_uv.x) * step(mortar_thickness, 1.0 - brick_uv.x);
	float y_mask = step(mortar_thickness, brick_uv.y) * step(mortar_thickness, 1.0 - brick_uv.y);
	float brick_mask = x_mask * y_mask;

	float variation = 1.0 - variation_strength + variation_strength * (0.5 + 0.5 * sin((row + floor(uv.x * brick_columns)) * 2.31));
	vec3 color = mix(mortar_color.rgb, brick_color.rgb * variation, brick_mask);

	ALBEDO = color;
	ROUGHNESS = 0.92;
	METALLIC = 0.0;
}
"

